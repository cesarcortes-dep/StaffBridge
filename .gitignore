# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# SQLite lives in /public so Next.js auto-bundles it on Vercel.
# To regenerate: `npm run db:seed && npm run themes:embed && npm run themes:label`.
/data/reviews.db
/data/reviews.db-journal
/data/reviews.db-wal
/data/reviews.db-shm
/public/reviews.db-journal
/public/reviews.db-wal
/public/reviews.db-shm

# Internal notes (not for submission)
_demo-prep.md
_build-log.md

# Generated by scripts/embed-db.ts during build — Vercel regenerates it
/src/lib/reviews-db.generated.ts

# Exam materials (recruiter IP, don't republish)
EXAM-*.docx
INSTRUCTIONS-*.docx
